# Security hardening for pnpm
# Blocks postinstall scripts — a major supply chain attack vector.
# Run `pnpm rebuild` manually when a package legitimately needs scripts.
ignore-scripts=true

# Enforce SSL for all registry connections
strict-ssl=true

# Fail on peer dependency mismatches instead of silently ignoring them
strict-peer-dependencies=true

# Automatically install peer dependencies
auto-install-peers=true

# Use the highest compatible version when resolving dependencies
resolution-mode=highest
